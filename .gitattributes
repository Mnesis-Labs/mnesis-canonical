# Keep wire/text formats byte-stable across platforms so manifest jsonlSizeBytes
# (and diffs) stay deterministic. Episode data is LF-only.
*.jsonl text eol=lf
*.json  text eol=lf
*.py    text eol=lf
*.md    text eol=lf
*.toml  text eol=lf

# Importer test fixtures are binary containers — never normalize line endings.
*.pkl   binary
*.mcap  binary
